# Server Configuration
NODE_ENV="development"
PORT=3001

# Supabase Configuration
SUPABASE_URL="https://[XPTO].supabase.co"
SUPABASE_ANON_KEY="[XPTO]"
SUPABASE_SERVICE_ROLE_KEY="[XPTO]"

# Database Configuration (for Prisma)
DATABASE_URL="postgresql://postgres.[XPTO]:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[XPTO]:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# JWT Configuration
JWT_SECRET="[XPTO]"
JWT_EXPIRES_IN="7d"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# Recaptcha
RECAPTCHA_SECRET_KEY="[XPTO]"