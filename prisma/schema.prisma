generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  relationMode = "prisma"
}

model Instituicao {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?  @unique
  endereco  String?
  telefone  String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     Users[]
  eventos   Eventos[]
  areas     Area[]

  @@map("instituicoes")
}

model Users {
  id            String   @id @default(uuid())
  email         String   @unique
  nome          String
  telefone      String?
  rg            String?
  cpf           String?  @unique
  userType      String   @default("membro")
  instituicaoId String
  pix_key       String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  eventos       Eventos[]
  areas         UserArea[]

  @@index([instituicaoId])
  @@index([email])
  @@index([cpf])
  @@map("users")
}

model Area {
  id            String   @id @default(uuid())
  nome          String
  instituicaoId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  users         UserArea[]

  @@index([instituicaoId])
  @@map("areas")
}

model UserArea {
  id        String   @id @default(uuid())
  userId    String
  areaId    String
  cargo     String   // voluntário, líder, vice-líder
  createdAt DateTime @default(now())

  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([userId, areaId])
  @@index([userId])
  @@index([areaId])
  @@map("user_areas")
}

model Eventos {
  id                   String   @id @default(uuid())
  nome                 String
  data_inicio          DateTime
  data_fim             DateTime
  descricao            String?
  selecao_unica_produto Boolean  @default(true)
  imagem_url           String?
  userId               String?
  instituicaoId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 Users?       @relation(fields: [userId], references: [id])
  instituicao          Instituicao? @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  participantes        Participantes[]
  produtos             ProdutosEvento[]

  @@index([userId])
  @@index([instituicaoId])
  @@map("eventos")
}

model Participantes {
  id             String   @id @default(uuid())
  eventoId       String
  nome           String
  email          String
  telefone       String
  rg             String
  cpf            String
  termo_assinado Boolean
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  evento         Eventos  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  produtos       ParticipanteProdutos[]

  @@unique([eventoId, cpf])
  @@index([eventoId])
  @@map("participantes")
}

model ProdutosEvento {
  id          String   @id @default(uuid())
  eventoId    String
  nome        String
  descricao   String?
  valor       Decimal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  evento      Eventos  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  participantes ParticipanteProdutos[]

  @@index([eventoId])
  @@map("produtos_evento")
}

model ParticipanteProdutos {
  id             String   @id @default(uuid())
  participanteId String
  produtoId      String
  valor_pago     Decimal
  data_pagamento DateTime?
  createdAt      DateTime @default(now())
  
  participante   Participantes @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  produto        ProdutosEvento @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([participanteId, produtoId])
  @@index([participanteId])
  @@index([produtoId])
  @@map("participante_produtos")
}
